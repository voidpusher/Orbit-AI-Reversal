# Frontend (Next.js) environment. Copy to .env.local for local development.

# Base URL of the Orbit API.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional Sentry DSN for client-side error reporting. Leave unset to disable;
# errors still log to the console via the ErrorBoundary.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# Durable production analyses (requires shared Postgres storage)
ORBIT_QUEUE_DRIVER=in_process
ORBIT_QUEUE_ENQUEUE_URL=http://localhost:3000/api/analysis-jobs/enqueue
