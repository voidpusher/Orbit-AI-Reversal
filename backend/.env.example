ORBIT_ENVIRONMENT=development
ORBIT_DATABASE_URL=sqlite+aiosqlite:///./orbit.db
ORBIT_QUEUE_DRIVER=in_process
# Vercel production: set to vercel only after DATABASE_URL points to Postgres.
ORBIT_QUEUE_ENQUEUE_URL=http://localhost:3000/api/analysis-jobs/enqueue
# Run `alembic upgrade head` on startup (production). Dev/tests use create_all when false.
ORBIT_RUN_MIGRATIONS_ON_STARTUP=false
# Optional Sentry error tracking (activates only when set + sentry-sdk installed).
# ORBIT_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# For production:
# ORBIT_DATABASE_URL=postgresql+asyncpg://orbit:orbit@localhost:5432/orbit
# ORBIT_REDIS_URL=redis://localhost:6379/0
# ORBIT_QUEUE_DRIVER=redis
ORBIT_ALLOWED_ANALYSIS_HOSTS=
ORBIT_MAX_PAGES=20
ORBIT_MAX_ANALYSIS_SECONDS=120
# Optional serverless-browser bridge used by Vercel deployments.
# ORBIT_BROWSER_CAPTURE_URL=https://your-app.vercel.app/api/browser-capture
# ORBIT_CAPTURE_SECRET=replace-with-a-long-random-secret

# Optional model provider for narrative synthesis. With no key, the analyzer
# produces deterministic prose so the pipeline works fully offline.
# ORBIT_OPENAI_API_KEY=sk-...
ORBIT_OPENAI_MODEL=gpt-5
ORBIT_OPENAI_BASE_URL=https://api.openai.com/v1

# OAuth social sign-in. A provider's buttons activate only when both its id and
# secret are set. Register the callback URL shown below with each provider.
ORBIT_PUBLIC_BASE_URL=http://localhost:8000
ORBIT_FRONTEND_BASE_URL=http://localhost:3000
# Google — authorized redirect URI: {PUBLIC_BASE_URL}/api/v1/auth/oauth/google/callback
# ORBIT_GOOGLE_CLIENT_ID=
# ORBIT_GOOGLE_CLIENT_SECRET=
# GitHub — authorization callback URL: {PUBLIC_BASE_URL}/api/v1/auth/oauth/github/callback
# ORBIT_GITHUB_CLIENT_ID=
# ORBIT_GITHUB_CLIENT_SECRET=
